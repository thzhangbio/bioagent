# 飞书应用凭证（从飞书开放平台获取）
# https://open.feishu.cn → 你的应用 → 凭证与基础信息
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# Claude API Key（APIMart 中转站密钥，sk-xxxx 格式）
ANTHROPIC_API_KEY=

# APIMart 中转站地址（不要改，除非你换了中转站）
ANTHROPIC_BASE_URL=https://api.apimart.ai

# Claude 模型 ID（须与 APIMart 控制台展示的完全一致）
ANTHROPIC_MODEL=claude-sonnet-4-6

# RAG：Embedding（与 Claude 分离；APIMart OpenAI 兼容 /v1/embeddings）
# 密钥可与上一行 ANTHROPIC_API_KEY 相同（同一 APIMart sk）
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.apimart.ai/v1
# 质量优先用 large；若成本敏感可改为 text-embedding-3-small
EMBEDDING_MODEL=text-embedding-3-large
