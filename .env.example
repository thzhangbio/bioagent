# 飞书应用凭证（从飞书开放平台获取）
# https://open.feishu.cn → 你的应用 → 凭证与基础信息
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# 可选：生成云文档浏览器链接时的站点根（默认 https://feishu.cn）；自建或国际版可改为 https://your-domain.feishu.cn 等
# FEISHU_WEB_BASE=https://feishu.cn

# 可选：新建云文档时的父目录（云空间文件夹 token）；不设则落在应用默认位置
# FEISHU_DOC_FOLDER_TOKEN=

# 创建 docx 后为发消息用户添加「可管理」协作者，需在开放平台为应用开通云文档/云空间协作者相关权限（见 drive permission-member create）
# 设为 1 可跳过添加协作者（仅调试用）
# FEISHU_DOC_DISABLE_USER_GRANT=1

# 设为 1 时关闭「写作简报」触发的强制通过闸门（排障用；默认不设置）
# FEISHU_CONTENT_FORCE_GATE=1

# 内容创作：设为 1 时恢复「动笔前严格追问 + 小红书机械对齐追问」（默认不设=宽松：先出协作稿，合规后置）
# FEISHU_CONTENT_STRICT_GATE=1

# 成稿后是否自动跑一次 LLM 合规协审（默认开启；设为 0 关闭以省 token）
# FEISHU_COMPLIANCE_AFTER_WRITE=0

# 飞书 OpenAPI 遇 TLS/断连时的最大重试次数（默认 4）
# FEISHU_API_MAX_RETRIES=4

# 设为 1：识别到「内容创作」意图后下发飞书交互卡片（结构化勾选），点「开始生成」后跳过多轮追问直接成稿（省 token）
# 须在开放平台 → 事件与回调：
#   1）订阅「卡片回传交互」card.action.trigger，且与 IM 一致使用「长连接」接收；
#   2）若客户端仍报 code:200340：在「回调配置」填写任意可公网访问的 HTTPS 地址（可用占位 URL），保存并发布应用版本——部分租户仍校验该字段；
#   3）修改订阅或回调后务必「创建版本并发布」使配置生效。
# FEISHU_CONTENT_CARD_FORM=1

# Claude API Key（APIMart 中转站密钥，sk-xxxx 格式）
ANTHROPIC_API_KEY=

# APIMart 中转站地址（不要改，除非你换了中转站）
ANTHROPIC_BASE_URL=https://api.apimart.ai

# Claude 模型 ID（须与 APIMart 控制台展示的完全一致）
ANTHROPIC_MODEL=claude-sonnet-4-6

# RAG：Embedding（与 Claude 分离；APIMart OpenAI 兼容 /v1/embeddings）
# 密钥可与上一行 ANTHROPIC_API_KEY 相同（同一 APIMart sk）
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.apimart.ai/v1
# 质量优先用 large；若成本敏感可改为 text-embedding-3-small
EMBEDDING_MODEL=text-embedding-3-large

# 可选：DEBUG_RAG=1 时打印 RAG 入库与检索相关调试信息（勿在生产长期开启）
# DEBUG_RAG=1

# 设为 1 时终端日志打印用户消息与助手回复全文（默认仅长度 + 前 80 字预览，见根目录 README）
# DEBUG_CONTENT=1

# 可选：微信公众号文章清洗侧车工具 — 拉取阅读/点赞/转发等互动数据（pnpm run wechat-article-pipeline -- --clean-only --fetch-stats）
# 在已登录微信的浏览器打开 mp 文章页，从开发者工具复制 Cookie；勿提交真实值到仓库
# WECHAT_MP_COOKIE=

# 可选：微信成稿灌库 ingest:wechat — 覆盖默认目录（默认 side-tools/wechat-article-cleanup/out/）
# WECHAT_STYLE_INBOX=

# 可选：ingest:wechat 当 .md 无 wechat_style_variant 且无 .meta.json 时的子风格（medsci | liangyi_hui）
# WECHAT_DEFAULT_VARIANT=medsci
