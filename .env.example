# 飞书应用凭证（从飞书开放平台获取）
# https://open.feishu.cn → 你的应用 → 凭证与基础信息
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# Claude API Key（APIMart 中转站密钥，sk-xxxx 格式）
ANTHROPIC_API_KEY=

# APIMart 中转站地址（不要改，除非你换了中转站）
ANTHROPIC_BASE_URL=https://api.apimart.ai

# 可选：指定 Claude 模型（开发用 Sonnet，正式用 Opus）
ANTHROPIC_MODEL=claude-sonnet-4-20250514
