{
  "name": "bioagent",
  "version": "0.1.0",
  "description": "医学编辑 AI 员工 — 基于飞书的类真人内容助手",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc",
    "lint": "tsc --noEmit",
    "probe:feishu": "tsx scripts/feishu-ws-probe.ts",
    "probe:docx": "tsx scripts/probe-docx.ts",
    "ingest:presets": "tsx scripts/ingest-presets.ts",
    "ingest:jobs": "tsx scripts/ingest-job-posts.ts",
    "ingest:literature": "tsx scripts/ingest-literature.ts",
    "ingest:wechat": "tsx scripts/ingest-wechat.ts",
    "ingest:all": "pnpm run ingest:presets && pnpm run ingest:jobs",
    "search:rag": "tsx scripts/search-rag.ts",
    "report:explicit-state": "tsx scripts/report-explicit-state.ts",
    "knowledge-import": "tsx tools/knowledge-importer/cli/knowledge-import.ts",
    "refresh:chat-docx-index": "tsx scripts/refresh-chat-docx-index.ts",
    "search:jobs": "tsx scripts/search-job-posts.ts",
    "pdf-cleanup": "tsx side-tools/pdf-text-cleanup/pyramid/tools/pdf-cleanup/pdf-cleanup.ts",
    "pdf-kb-pipeline": "tsx side-tools/pdf-text-cleanup/pyramid/segment-inbox-to-out/segment-inbox-to-out.ts",
    "pdf-kb-inbox-to-out": "tsx side-tools/pdf-text-cleanup/pyramid/segment-inbox-to-out/segment-inbox-to-out.ts",
    "pdf-kb-out-to-knowledge": "tsx side-tools/pdf-text-cleanup/pyramid/segment-out-to-knowledge/segment-out-to-knowledge.ts",
    "pdf-kb-out-to-archive": "tsx side-tools/pdf-text-cleanup/pyramid/segment-out-to-archive/segment-out-to-archive.ts",
    "pdf-kb-fragment-audit": "tsx side-tools/pdf-text-cleanup/pyramid/segment-inbox-to-out/09-formula-fragments/fragment-audit.ts",
    "pdf-kb-fragment-list": "tsx side-tools/pdf-text-cleanup/pyramid/segment-inbox-to-out/09-formula-fragments/fragment-list.ts",
    "pdf-kb-fragment-apply-inplace": "tsx side-tools/pdf-text-cleanup/pyramid/segment-inbox-to-out/09-formula-fragments/fragment-apply-inplace.ts",
    "pdf-kb-generic-cleanup-apply-inplace": "tsx side-tools/pdf-text-cleanup/pyramid/segment-inbox-to-out/07-cleanup-generic/cleanup-apply-inplace.ts",
    "pdf-kb-fragment-fixtures": "tsx side-tools/pdf-text-cleanup/pyramid/segment-inbox-to-out/09-formula-fragments/fragment-fixtures-check.ts",
    "pdf-archive-inbox": "tsx side-tools/pdf-text-cleanup/pyramid/segment-out-to-archive/segment-out-to-archive.ts --mode inbox-only",
    "pdf-archive-out": "tsx side-tools/pdf-text-cleanup/pyramid/segment-out-to-archive/segment-out-to-archive.ts --mode out-only",
    "pdf-archive-legacy-flat": "tsx side-tools/pdf-text-cleanup/pyramid/segment-out-to-archive/legacy-flat-archive/legacy-flat-archive.ts",
    "wechat-article-pipeline": "tsx side-tools/wechat-article-cleanup/pyramid/wechat-article-cleanup.ts",
    "wechat-article-clean": "tsx side-tools/wechat-article-cleanup/pyramid/tools/wechat-article-clean/wechat-article-clean.ts",
    "wechat-article-out-to-knowledge": "tsx side-tools/wechat-article-cleanup/pyramid/segment-out-to-knowledge/segment-out-to-knowledge.ts",
    "wechat-article-out-to-archive": "tsx side-tools/wechat-article-cleanup/pyramid/segment-out-to-archive/segment-out-to-archive.ts",
    "wechat-article-archive-inbox": "tsx side-tools/wechat-article-cleanup/pyramid/segment-out-to-archive/segment-out-to-archive.ts --mode inbox-only",
    "wechat-article-archive-out": "tsx side-tools/wechat-article-cleanup/pyramid/segment-out-to-archive/segment-out-to-archive.ts --mode out-only"
  },
  "keywords": [
    "feishu",
    "lark",
    "medical",
    "ai-agent"
  ],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.11.0",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.81.0",
    "@larksuiteoapi/node-sdk": "^1.60.0",
    "dotenv": "^17.3.1",
    "openai": "^6.33.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "devDependencies": {
    "@types/node": "^25.5.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "protobufjs"
    ]
  }
}
