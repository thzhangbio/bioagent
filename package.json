{
  "name": "bioagent",
  "version": "0.1.0",
  "description": "医学编辑 AI 员工 — 基于飞书的类真人内容助手",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc",
    "lint": "tsc --noEmit",
    "probe:feishu": "tsx scripts/feishu-ws-probe.ts",
    "probe:docx": "tsx scripts/probe-docx.ts",
    "ingest:presets": "tsx scripts/ingest-presets.ts",
    "ingest:jobs": "tsx scripts/ingest-job-posts.ts",
    "ingest:literature": "tsx scripts/ingest-literature.ts",
    "ingest:all": "pnpm run ingest:presets && pnpm run ingest:jobs",
    "search:rag": "tsx scripts/search-rag.ts",
    "search:jobs": "tsx scripts/search-job-posts.ts",
    "pdf-cleanup": "tsx side-tools/pdf-text-cleanup/cli.ts",
    "pdf-kb-pipeline": "tsx side-tools/pdf-text-cleanup/pipeline.ts",
    "pdf-archive-inbox": "tsx side-tools/pdf-text-cleanup/archive-inbox.ts",
    "pdf-archive-out": "tsx side-tools/pdf-text-cleanup/archive-out.ts",
    "pdf-archive-legacy-flat": "tsx side-tools/pdf-text-cleanup/archive-legacy-flat.ts",
    "wechat-article-pipeline": "tsx side-tools/wechat-article-cleanup/pipeline.ts",
    "wechat-article-clean": "tsx side-tools/wechat-article-cleanup/cli.ts",
    "wechat-article-archive-inbox": "tsx side-tools/wechat-article-cleanup/archive-inbox.ts",
    "wechat-article-archive-out": "tsx side-tools/wechat-article-cleanup/archive-out.ts"
  },
  "keywords": [
    "feishu",
    "lark",
    "medical",
    "ai-agent"
  ],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.11.0",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.81.0",
    "@larksuiteoapi/node-sdk": "^1.60.0",
    "dotenv": "^17.3.1",
    "openai": "^6.33.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "devDependencies": {
    "@types/node": "^25.5.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "protobufjs"
    ]
  }
}
